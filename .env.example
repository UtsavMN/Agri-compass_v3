# Agri Compass Frontend Configuration

# Backend API URL (Default for local Spring Boot)
VITE_API_URL=http://localhost:8080

# Copy this file to .env and fill in your own API keys.
# Do not commit .env to git. It is ignored by the repository.

VITE_OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_DATA_GOV_API_KEY=YOUR_DATA_GOV_API_KEY
