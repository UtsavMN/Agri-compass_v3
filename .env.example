# ==============================================================================
# AGRI-COMPASS ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env and fill in your actual credentials.
# DO NOT COMMIT your actual .env file to version control!

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Vite)
# ------------------------------------------------------------------------------
# Ensure the backend is running on this port for local development
VITE_API_URL=http://localhost:8080

# Frontend API Keys (If making direct calls from React)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_DATA_GOV_API_KEY=your_data_gov_api_key_here

# ------------------------------------------------------------------------------
# BACKEND CONFIGURATION (Spring Boot)
# ------------------------------------------------------------------------------
# Server Port
PORT=8080

# Database Configuration
# Use local SQLite by default: jdbc:sqlite:agri.db
# For Turso, use: jdbc:dbeaver:libsql:https://[YOUR_DB].turso.io
DB_URL=jdbc:sqlite:agri.db

# Turso Authentication Token (Optional, only if using Turso)
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Clerk Authentication (OAuth2 Resource Server)
CLERK_ISSUER_URI=https://delicate-moth-5.clerk.accounts.dev

# SMTP / Email Configuration (Gmail App Password)
# To get an app password: Google Account -> Security -> 2-Step Verification -> App Passwords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_password

# ------------------------------------------------------------------------------
# EXTERNAL APIs
# ------------------------------------------------------------------------------
# Gemini API Key (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API Key (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Data.gov.in API Key (https://www.data.gov.in/)
DATA_GOV_API_KEY=your_data_gov_api_key_here
